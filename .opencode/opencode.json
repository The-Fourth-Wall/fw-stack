{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "disable_paste_summary": true
  },
  "permission": {
    "*": "allow"
  },
  "agent": {
    "build": {
      "color": "primary"
    }
  },
  "plugin": ["./plugins/opencode-cursor/index.js"],
  "provider": {
    "cursor": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      },
      "models": {
        "claude-4.5-opus-high-thinking": {"name": "Opus 4.5"},
        "claude-4.6-opus-high-thinking": {"name": "Opus 4.6"},
        "claude-4.6-opus-max-thinking": {"name": "Opus 4.6 Max"},
        "claude-opus-4-7-thinking-high": {"name": "Opus 4.7 High"},
        "claude-opus-4-7-thinking-xhigh": {"name": "Opus 4.7 xHigh"},
        "claude-opus-4-7-thinking-max": {"name": "Opus 4.7 Max"},
        "claude-4.5-sonnet-thinking": {"name": "Sonnet 4.5"},
        "claude-4.6-sonnet-medium-thinking": {"name": "Sonnet 4.6"},
        "composer-2": {"name": "Composer 2"},
        "composer-2-fast": {"name": "Composer 2 Fast"},
        "gemini-3.1-pro": {"name": "Gemini 3.1 Pro"},
        "gpt-5.4-medium": {"name": "GPT-5.4 Medium"},
        "gpt-5.4-high": {"name": "GPT-5.4 High"},
        "gpt-5.5-medium": {"name": "GPT-5.5 Medium"},
        "grok-4-20-thinking": {"name": "Grok 4.20 Thinking"}
      }
    },
    "opencode-go": {
      "blacklist": [
        "glm-5",
        "kimi-k2.5",
        "mimo-v2-omni",
        "mimo-v2-pro",
        "mimo-v2.5",
        "minimax-m2.5",
        "qwen3.5-plus"
      ],
      "options": {
        "apiKey": "{file:keys/opencode-go}"
      }
    },
    "mimo": {
      "blacklist": [],
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiMo",
      "options": {
        "baseURL": "https://token-plan-ams.xiaomimimo.com/v1",
        "apiKey": "{file:keys/xiaomi-token-plan}"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "MiMo-V2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "reasoning": true
        }
      }
    },
    "zai-coding-plan": {
      "blacklist": ["glm-5-turbo", "glm-4.5-air", "glm-4.7"],
      "options": {
        "apiKey": "{file:keys/zai-coding-plan}"
      }
    }
  },
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server@latest"],
      "environment": {
        "Z_AI_API_KEY": "{file:keys/zai-coding-plan}",
        "Z_AI_MODE": "ZAI"
      }
    }
  }
}
