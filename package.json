{
  "name": "fw-stack",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "run:dev": "astro dev --mode dev",
    "run:stage": "astro dev --mode stage",
    "run:preprod": "astro dev --mode preprod",
    "run:prod": "astro dev --mode prod",
    "convex:deploy:dev": "ruby scripts/convex-deploy.rb dev",
    "convex:deploy:stage": "ruby scripts/convex-deploy.rb stage",
    "convex:deploy:preprod": "ruby scripts/convex-deploy.rb preprod",
    "convex:deploy:prod": "ruby scripts/convex-deploy.rb prod",
    "prettier": "prettier --write .",
    "eslint": "eslint .",
    "check": "astro check",
    "convex:types": "ruby scripts/convex-codegen.rb",
    "convex:check": "convex typecheck",
    "lint": "ruby scripts/lint.rb",
    "loc": "ruby scripts/loc.rb",
    "skills": "rm -rf .agents .claude && skills experimental_install && cp -r .agents .claude",
    "purge": "ruby scripts/purge.rb",
    "clean": "ruby scripts/clean.rb",
    "start": "node ./dist/server/entry.mjs",
    "build": "pnpm lint && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.26",
    "@astrojs/node": "^10.0.6",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.6",
    "@nanostores/react": "^1.1.0",
    "@swup/head-plugin": "^2.3.1",
    "@swup/js-plugin": "^3.2.0",
    "@swup/scripts-plugin": "^2.1.0",
    "@swup/scroll-plugin": "^4.0.0",
    "astro": "^6.2.1",
    "astro-seo": "^1.1.0",
    "convex": "^1.37.0",
    "gsap": "^3.15.0",
    "lenis": "1.3.17",
    "lucide-react": "0.525.0",
    "nanostores": "^1.3.0",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^11.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "swup": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "cssnano": "^7.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
